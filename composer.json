{
    "name": "giveledger/giveledger",
    "description": "Multi-tenant giving campaign tracker for churches",
    "type": "project",
    "require": {
        "php": "^8.3",
        "ext-redis": "*",
        "ramsey/uuid": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "jetbrains/phpstorm-stubs": "^2026.1"
    }
}
